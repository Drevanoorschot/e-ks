{
  "$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",

  "files": {
    "includes": [
      "frontend/scripts/**/*.ts",
      "frontend/styles/**/*.css",
      "playwright/tests/**/*.ts"
    ],
    "ignoreUnknown": true
  },

  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,

      "suspicious": {
        "noConsole": "off"
      },

      "correctness": {
        "noUnusedVariables": "error",
        "noUndeclaredVariables": "error"
      },

      "style": {
        "useConst": "error"
      }
    }
  }
}
