{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eks-offline",
  "version": "0.1.0",
  "identifier": "nl.kiesraad.kandidaatstellen.eks-offline",
  "build": {
    "frontendDist": "axum://localhost"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "eks-offline",
        "width": 1200,
        "height": 800,
        "url": "axum://localhost/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
