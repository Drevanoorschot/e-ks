#!/bin/bash

set -euo pipefail

./bin/esbuild --bundle frontend/index.ts \
    --outdir=frontend/static \
    --minify \
    --sourcemap \
    --define:IS_PRODUCTION=true \
    --loader:.woff2=file \
    --loader:.svg=file \
    --public-path=/static/

cp frontend/favicon.svg frontend/static/favicon.svg

cargo build \
    --features "$CARGO_SET_FEATURES" \
    --no-default-features \
    --release \
    --bin eks
