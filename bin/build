#!/bin/bash

set -euo pipefail

TARGET_ARGS=()
if [[ "${1:-}" == "--target" ]]; then
  TARGET_ARGS=(--target "${2:?missing value for --target}")
  shift 2
fi

./bin/esbuild --bundle frontend/index.ts \
    --outdir=frontend/static \
    --minify \
    --sourcemap \
    --define:IS_PRODUCTION=true \
    --loader:.woff2=file \
    --loader:.svg=file \
    --public-path=/static/

cp frontend/favicon.svg frontend/static/favicon.svg

cargo build \
    --features memory-serve,database,migrations,fixtures \
    --no-default-features \
    --release \
    --bin eks \
    "${TARGET_ARGS[@]}"
