#!/bin/bash

set -euo pipefail

export MEMORY_SERVE_QUIET=1

# rust
cargo check
cargo +nightly fmt --all -- --config imports_granularity="Crate"
cargo clippy --all-targets -- -D warnings
cargo test

# typescript
./bin/biome check --fix ./frontend
./bin/biome check --fix ./playwright/tests

# html
docker run --rm -v ./src/app:/work/templates djlint

# generic
./bin/check_newline
./bin/update_locales
