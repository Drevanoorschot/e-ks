#!/bin/bash

set -euo pipefail

export MEMORY_SERVE_QUIET=1

# rust
cargo check --all-features
cargo +nightly fmt --all -- --config imports_granularity="Crate"
cargo clippy --all-targets --all-features -- -D warnings
cargo test --all-features

# typescript
./bin/biome check --fix ./frontend
./bin/biome check --fix ./playwright/tests

# html
docker run --rm \
    -v ./src/app:/work/templates \
    djlint \
    djlint --ignore=H025 --lint --extension=html --check --indent=2 templates

# generic
./bin/check_newline
./bin/update_locales
